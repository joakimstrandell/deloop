{
  "name": "deloop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "pnpm exec oxlint .",
    "format": "pnpm exec oxfmt .",
    "format:check": "pnpm exec oxfmt --check .",
    "check": "pnpm lint && pnpm format:check && pnpm --recursive run check",
    "test:unit": "pnpm --recursive run test:unit",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "install:browsers": "playwright install chromium",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm exec oxlint --fix",
      "pnpm exec oxfmt"
    ],
    "*.{json,jsonc}": [
      "pnpm exec oxfmt"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@playwright/test"
    ]
  }
}
